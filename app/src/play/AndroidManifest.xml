<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Play restricts MANAGE_EXTERNAL_STORAGE to app categories that do not include
         emulators, so the play flavour genuinely lacks the capability rather than hiding
         it: the permission is stripped at merge time and the scan-all UI routes to the
         SAF folder picker (see MainActivity.startStorageScan). -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:node="remove" />

</manifest>
