<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ROM import is SAF-only (folder picker / file picker): no storage permission at all,
         which is also what keeps the app Play-eligible. Legacy READ for pre-SAF devices. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Core-driven rumble. The touch pad's own haptics go through performHapticFeedback, which
         needs no permission - which is why the pad has always buzzed while rumble did nothing. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="true" />

    <uses-feature
        android:name="android.hardware.sensor.gyroscope"
        android:required="false" />

    <application
        android:name=".RetroGlassApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.RetroGlass">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.RetroGlass">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <activity
            android:name=".EmulationActivity"
            android:exported="false"
            android:screenOrientation="user"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:launchMode="singleTask" />

    </application>
</manifest>
