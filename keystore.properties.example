# Copy to keystore.properties (git-ignored) and fill in to produce a signed release build.
# Without this file the release build is left unsigned, deliberately: falling back to the
# debug certificate produces an APK Play will reject, and a build-time failure is easier to
# understand than a rejected submission.
#
# Generate a key once, and keep the .jks and these passwords somewhere you will not lose them
# — Play ties the app listing to this certificate permanently:
#
#   keytool -genkey -v -keystore retroglass.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias retroglass
storeFile=retroglass.jks
storePassword=
keyAlias=retroglass
keyPassword=
